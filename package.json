{
  "name": "library-fetcher",
  "version": "0.1.0",
  "description": "OpenClaw plugin that searches a configured web library and downloads books into a local cache.",
  "type": "module",
  "main": "index.mjs",
  "bin": {
    "claw-library-fetch": "./bin/claw-library-fetch.mjs"
  },
  "files": [
    "bin",
    "index.mjs",
    "openclaw.plugin.json",
    "playbooks",
    "src"
  ],
  "openclaw": {
    "extensions": [
      "./index.mjs"
    ]
  },
  "dependencies": {
    "playwright": "^1.58.2"
  }
}
